{
  "name": "worker",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/worker/src",
  "targets": {
    "dev": {
      "command": "wrangler dev",
      "options": { "cwd": "apps/worker" }
    },
    "deploy": {
      "command": "wrangler deploy",
      "options": { "cwd": "apps/worker" }
    },
    "build": {
      "command": "tsc --noEmit",
      "options": { "cwd": "apps/worker" }
    }
  }
}
